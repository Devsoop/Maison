{%- assign popup_trigger_id = section.settings.popup_trigger_id | strip -%}
{%- if popup_trigger_id != blank -%}
  {%- assign popup_trigger_id = popup_trigger_id | remove_first: '#' -%}
{%- endif -%}
{%- assign popup_color_scheme_id = section.settings.color_scheme.id | default: section.settings.color_scheme -%}
{%- assign popup_trigger_selector = '' -%}
{%- if popup_trigger_id != blank -%}
  {%- assign popup_trigger_selector = '#' | append: popup_trigger_id -%}
{%- endif -%}
{%- assign klaviyo_form_id = '' -%}
{%- if section.settings.klaviyo_markup contains 'klaviyo-form-' -%}
  {%- assign klaviyo_form_id = section.settings.klaviyo_markup | split: 'klaviyo-form-' | last | split: '"' | first | split: "'" | first | split: ' ' | first | strip -%}
{%- endif -%}

<pop-in
  id="klaviyo-popup-{{ section.id }}"
  class="pop-in klaviyo-popup color-scheme color-scheme--{{ popup_color_scheme_id }}"
  title="{{ section.settings.heading | default: 'Klaviyo popup' | escape }}"
  handle-editor-events
  data-trigger-id="{{ popup_trigger_id }}"
  data-trigger-selector="{{ popup_trigger_selector }}"
>
  <dialog-close-button class="contents">
    <button class="pop-in__close-button tap-area" type="button">
      <span class="sr-only">{{ 'general.accessibility.close' | t }}</span>
      {%- render 'icon' with 'close' -%}
    </button>
  </dialog-close-button>

  <div class="v-stack gap-6">
    {%- if section.settings.heading != blank -%}
      <h2 class="h4">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p>{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div data-klaviyo-form-root>
      {%- if section.settings.klaviyo_markup != blank -%}
        {{ section.settings.klaviyo_markup }}
      {%- endif -%}
    </div>

    {%- if section.settings.description != blank -%}
      <p>{{ section.settings.description }}</p>
    {%- endif -%}
  </div>
</pop-in>
<div id="klaviyo-popup-overlay-{{ section.id }}" class="klaviyo-popup-overlay" hidden></div>
<div id="klaviyo-popup-toast-{{ section.id }}" class="klaviyo-popup-toast" hidden></div>
<template id="klaviyo-popup-form-template-{{ section.id }}">
  {{ section.settings.klaviyo_markup }}
</template>

<script>
  (() => {
    const popup = document.getElementById('klaviyo-popup-{{ section.id }}');
    if (!popup) return;
    if (popup.dataset.klaviyoPopupInit === 'true') return;
    popup.dataset.klaviyoPopupInit = 'true';

    const overlay = document.getElementById('klaviyo-popup-overlay-{{ section.id }}');
    const toast = document.getElementById('klaviyo-popup-toast-{{ section.id }}');
    const formRoot = popup.querySelector('[data-klaviyo-form-root]');
    const formTemplate = document.getElementById('klaviyo-popup-form-template-{{ section.id }}');
    const klaviyoFormId = '{{ klaviyo_form_id }}';

    const LOCK_COUNT_ATTR = 'data-klaviyo-popup-lock-count';
    const SUCCESS_MESSAGE = 'Subscribed successfully.';
    const ERROR_MESSAGE = 'Subscription failed. Please try again.';
    const ALREADY_SUBSCRIBED_MESSAGE = 'You are already subscribed with this email.';
    const SUBSCRIBED_FLAG_KEY = `klaviyo-popup-subscribed:{{ section.id }}:${klaviyoFormId || 'default'}`;
    let klaviyoState = 'idle';
    let toastTimer;

    const lockBodyScroll = () => {
      const body = document.body;
      if (!body) return;

      const lockCount = Number(body.getAttribute(LOCK_COUNT_ATTR) || '0');

      if (lockCount === 0) {
        body.dataset.klaviyoPopupOverflow = body.style.overflow;
        body.style.overflow = 'hidden';
      }

      body.setAttribute(LOCK_COUNT_ATTR, String(lockCount + 1));
    };

    const unlockBodyScroll = () => {
      const body = document.body;
      if (!body) return;

      const lockCount = Number(body.getAttribute(LOCK_COUNT_ATTR) || '0');
      if (lockCount <= 1) {
        body.style.overflow = body.dataset.klaviyoPopupOverflow || '';
        delete body.dataset.klaviyoPopupOverflow;
        body.removeAttribute(LOCK_COUNT_ATTR);
        return;
      }

      body.setAttribute(LOCK_COUNT_ATTR, String(lockCount - 1));
    };

    const showToast = (message, type = 'success') => {
      if (!toast) return;

      clearTimeout(toastTimer);
      toast.textContent = message;
      toast.dataset.type = type;
      toast.hidden = false;

      requestAnimationFrame(() => toast.classList.add('is-visible'));

      toastTimer = window.setTimeout(() => {
        toast.classList.remove('is-visible');
        window.setTimeout(() => {
          toast.hidden = true;
        }, 200);
      }, 3000);
    };

    const resetKlaviyoForm = () => {
      if (!formRoot || !formTemplate) return;
      formRoot.innerHTML = formTemplate.innerHTML;
    };

    const hasAlreadySubscribed = () => localStorage.getItem(SUBSCRIBED_FLAG_KEY) === 'true';

    const setAlreadySubscribed = () => {
      localStorage.setItem(SUBSCRIBED_FLAG_KEY, 'true');
    };

    const renderAlreadySubscribedState = () => {
      if (!formRoot) return;
      formRoot.innerHTML = `<p class="text-subdued" role="status">${ALREADY_SUBSCRIBED_MESSAGE}</p>`;
    };

    const syncKlaviyoError = () => {
      if (!formRoot || klaviyoState !== 'submitting') return;

      const hasError = !!formRoot.querySelector(
        '.error_message, [data-testid*="error"], [aria-invalid="true"], [class*="error"]'
      );

      if (!hasError || klaviyoState === 'error') return;

      klaviyoState = 'error';
      showToast(ERROR_MESSAGE, 'error');
    };

    const handleKlaviyoSubmitSuccess = () => {
      if (klaviyoState === 'success') return;

      klaviyoState = 'success';
      setAlreadySubscribed();
      showToast(SUCCESS_MESSAGE, 'success');
      window.setTimeout(() => {
        popup.hide();
      }, 600);
    };

    popup.addEventListener('dialog:after-show', lockBodyScroll);
    popup.addEventListener('dialog:after-hide', unlockBodyScroll);
    popup.addEventListener('dialog:before-show', () => {
      klaviyoState = 'idle';
      if (hasAlreadySubscribed()) {
        renderAlreadySubscribedState();
      } else {
        resetKlaviyoForm();
      }
      if (!overlay) return;
      overlay.hidden = false;
      requestAnimationFrame(() => overlay.classList.add('is-visible'));
    });
    popup.addEventListener('dialog:after-hide', () => {
      if (!overlay) return;
      overlay.classList.remove('is-visible');
      overlay.hidden = true;
    });

    if (popup.hasAttribute('open')) {
      lockBodyScroll();
      if (overlay) {
        overlay.hidden = false;
        overlay.classList.add('is-visible');
      }
    }

    overlay?.addEventListener('click', () => popup.hide());
    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || !popup.hasAttribute('open')) return;
      event.preventDefault();
      popup.hide();
    });
    popup.addEventListener(
      'submit',
      (event) => {
        if (!(event.target instanceof HTMLFormElement)) return;
        klaviyoState = 'submitting';
      },
      true
    );
    window.addEventListener('klaviyoForms', (event) => {
      const detail = event.detail || {};

      if (detail.type !== 'submit') return;
      if (!popup.hasAttribute('open')) return;
      if (klaviyoFormId && detail.formId && detail.formId !== klaviyoFormId) return;

      handleKlaviyoSubmitSuccess();
    });

    const observer = new MutationObserver(() => {
      syncKlaviyoError();
    });
    if (formRoot) {
      observer.observe(formRoot, {
        childList: true,
        subtree: true,
        attributes: true,
        characterData: true
      });
    }
    popup.addEventListener('dialog:after-hide', () => {
      klaviyoState = 'idle';
      if (hasAlreadySubscribed()) {
        renderAlreadySubscribedState();
      } else {
        resetKlaviyoForm();
      }
    });

    if (popup.hasAttribute('open')) {
      if (hasAlreadySubscribed()) {
        renderAlreadySubscribedState();
      } else {
        resetKlaviyoForm();
      }
    }

    const triggerId = popup.dataset.triggerId;
    const triggerSelector = popup.dataset.triggerSelector;
    if (!triggerId || !triggerSelector) return;

    document.addEventListener('click', (event) => {
      const bySelector = event.target.closest(triggerSelector);
      const byHref = event.target.closest(`a[href="#${triggerId}"]`);

      if (!bySelector && !byHref) return;

      event.preventDefault();
      popup.show();
    });
  })();
</script>

{% style %}
  #klaviyo-popup-overlay-{{ section.id }} {
    position: fixed;
    inset: 0;
    z-index: 9;
    background: rgb(0 0 0 / 0.5);
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  #klaviyo-popup-overlay-{{ section.id }}.is-visible {
    opacity: 1;
  }

  #klaviyo-popup-toast-{{ section.id }} {
    position: fixed;
    inset-block-end: 1.25rem;
    inset-inline-start: 50%;
    translate: -50% 0;
    z-index: 12;
    min-width: 220px;
    max-width: calc(100vw - 2rem);
    border-radius: 999px;
    padding: 0.625rem 1rem;
    font-size: 0.8125rem;
    text-align: center;
    background: rgb(24 24 24 / 0.95);
    color: #fff;
    opacity: 0;
    transition: opacity 0.2s ease, translate 0.2s ease;
    pointer-events: none;
  }

  #klaviyo-popup-toast-{{ section.id }}[data-type='error'] {
    background: rgb(180 36 36 / 0.95);
  }

  #klaviyo-popup-toast-{{ section.id }}.is-visible {
    opacity: 1;
    translate: -50% -6px;
  }
  #klaviyo-popup-{{ section.id }}  .v-stack{
    gap:0!important;
  }
  #klaviyo-popup-{{ section.id }} {
    width: min(calc(100vw - 2rem), {{ section.settings.popup_width }}px);
    inset-block-start: 50%;
    inset-inline-start: 50%;
    inset-block-end: auto;
    inset-inline-end: auto;
    translate: -50% -50%;
    background-color: rgb(var(--background));
    background-image: var(--background-gradient);
    color: rgb(var(--text-color));
    border: 1px solid rgb(var(--border-color));
    text-align: center;
  }

  @media screen and (min-width: 700px) {
    #klaviyo-popup-{{ section.id }} {
      width: min(calc(100vw - 4rem), {{ section.settings.popup_width }}px);
    }
  }
  button.kl-private-reset-css-Xuajs1 {
  background: #b09b6e !important;
  font-weight: 100 !important;
  font-family: "Jost" !important;
  text-transform: uppercase;
  letter-spacing: 1.5px !important;
  font-size: 14px !important;
  border-radius: 0 !important;
}
{% endstyle %}

{% schema %}
{
  "name": "Klaviyo popup",
  "class": "shopify-section--popup",
  "enabled_on": {
    "groups": ["header", "footer", "aside"]
  },
  "settings": [
    {
      "type": "text",
      "id": "popup_trigger_id",
      "label": "ID field to open popup",
      "info": "Use a value like klavForm or #klavForm."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Join our list"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading (p)",
      "default": "Be the first to hear about launches and private offers."
    },
    {
      "type": "liquid",
      "id": "klaviyo_markup",
      "label": "Markup field",
      "default": "<div class=\"klaviyo-form-QQGVun\"></div>"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description (p)",
      "default": "No spam. Unsubscribe anytime."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-3"
    },
    {
      "type": "range",
      "id": "popup_width",
      "min": 320,
      "max": 760,
      "step": 10,
      "unit": "px",
      "label": "Popup width",
      "default": 440
    }
  ],
  "presets": [
    {
      "name": "Klaviyo popup"
    }
  ]
}
{% endschema %}
